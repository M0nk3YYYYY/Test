               <element name="REQUESTER_PERSON_ID" value="REQUESTER_PERSON_ID" label="REQUESTER_PERSON_ID" dataType="xsd:double" breakOrder="" fieldOrder="1"/>
               <element name="MANAGER_NAME" value="MANAGER_NAME" label="MANAGER_NAME" dataType="xsd:string" breakOrder="" fieldOrder="6"/>
               <element name="MANAGER_PERSON_ID" value="MANAGER_PERSON_ID" label="MANAGER_PERSON_ID" dataType="xsd:double" breakOrder="" fieldOrder="4"/>
               <element name="MANAGER_USERNAME" value="MANAGER_USERNAME" label="MANAGER_USERNAME" dataType="xsd:string" breakOrder="" fieldOrder="5"/>
