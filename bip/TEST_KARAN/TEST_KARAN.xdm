       AND NVL(mdn.effective_end_date, TO_DATE('4712-12-31', 'YYYY-MM-DD'))
  AND    mdn.manager_id IS NOT NULL
  AND    mdn.manager_id <> mdn.person_id
),
mgr_chain_raw AS (
  SELECT CAST(1 AS NUMBER(10,0)) AS lvl, TO_NUMBER(:requester_person_id) AS person_id
  FROM   dual
  UNION ALL
  SELECT CAST(LEVEL + 1 AS NUMBER(10,0)), e.manager_id
  FROM   mgr_edges e
  CONNECT BY NOCYCLE PRIOR e.manager_id = e.person_id
  START WITH e.person_id = TO_NUMBER(:requester_person_id)
),
mgr_chain_base AS (
  SELECT lvl, person_id
  FROM (
    SELECT r.lvl, r.person_id,
           ROW_NUMBER() OVER (PARTITION BY r.lvl, r.person_id ORDER BY r.lvl) AS rn
    FROM   mgr_chain_raw r
  )
  WHERE rn = 1
)
SELECT lvl, person_id
FROM   mgr_chain_base
ORDER BY lvl, person_id
-- AI Generated Code by Deloitte + Cursor (END)]]>
