      <dataSet name="user with manager" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[-- AI Generated Code by Deloitte + Cursor (BEGIN)
WITH requester AS (
  SELECT TO_NUMBER(:requester_person_id) AS person_id FROM dual
),
username_for_person AS (
  SELECT person_id, username
  FROM (
    SELECT u.person_id,
           u.username,
           ROW_NUMBER() OVER (
             PARTITION BY u.person_id
             ORDER BY NVL(u.last_update_date, u.creation_date) DESC
           ) AS rn
    FROM   per_users u
    WHERE  NVL(u.active_flag, 'Y') = 'Y'
  ) z
  WHERE z.rn = 1
),
name_for_person AS (
  SELECT person_id, display_name
  FROM   per_person_names_f ppn
  WHERE  ppn.name_type = 'GLOBAL'
  AND    TRUNC(SYSDATE) BETWEEN ppn.effective_start_date
       AND NVL(ppn.effective_end_date, TO_DATE('4712-12-31', 'YYYY-MM-DD'))
),
mgr_row AS (
  SELECT mdn.person_id,
         mdn.manager_id,
         ROW_NUMBER() OVER (
           PARTITION BY mdn.person_id
           ORDER BY mdn.effective_start_date DESC
         ) AS rn
  FROM   per_manager_hrchy_dn mdn
  WHERE  mdn.manager_type = 'LINE_MANAGER'
  AND    mdn.primary_manager_flag = 'Y'
  AND    TRUNC(SYSDATE) BETWEEN mdn.effective_start_date
       AND NVL(mdn.effective_end_date, TO_DATE('4712-12-31', 'YYYY-MM-DD'))
  AND    mdn.manager_id IS NOT NULL
  AND    mdn.manager_id <> mdn.person_id
  AND    mdn.person_id = TO_NUMBER(:requester_person_id)
)
SELECT
    r.person_id                                         AS user_person_id,
    uu.username                                         AS user_username,
    un.display_name                                     AS user_display_name,
    m.manager_id                                        AS manager_person_id,
    mu.username                                         AS manager_username,
    mn.display_name                                     AS manager_display_name
FROM   requester r
LEFT JOIN username_for_person uu ON uu.person_id = r.person_id
LEFT JOIN name_for_person     un ON un.person_id = r.person_id
LEFT JOIN mgr_row             m ON m.person_id = r.person_id AND m.rn = 1
LEFT JOIN username_for_person mu ON mu.person_id = m.manager_id
LEFT JOIN name_for_person     mn ON mn.person_id = m.manager_id
-- AI Generated Code by Deloitte + Cursor (END)]]>
         </sql>
      </dataSet>
      <dataSet name="New manager query" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[-- AI Generated Code by Deloitte + Cursor (BEGIN)
SELECT
    pu.person_id              AS requester_person_id,
    pu.username               AS user_name,
    ppnf_emp.full_name        AS employee_name,
    pasf.manager_id           AS manager_person_id,
    pu_mgr.username           AS manager_username,
    ppnf_mgr.full_name        AS manager_name
FROM   per_users pu
INNER JOIN per_person_names_f ppnf_emp
       ON ppnf_emp.person_id = pu.person_id
      AND ppnf_emp.name_type = 'GLOBAL'
      AND TRUNC(SYSDATE) BETWEEN ppnf_emp.effective_start_date
          AND NVL(ppnf_emp.effective_end_date, DATE '4712-12-31')
INNER JOIN per_assignment_supervisors_f pasf
       ON pasf.person_id = pu.person_id
      AND pasf.manager_type = 'LINE_MANAGER'
      AND TRUNC(SYSDATE) BETWEEN pasf.effective_start_date
          AND NVL(pasf.effective_end_date, DATE '4712-12-31')
INNER JOIN per_person_names_f ppnf_mgr
       ON ppnf_mgr.person_id = pasf.manager_id
      AND ppnf_mgr.name_type = 'GLOBAL'
      AND TRUNC(SYSDATE) BETWEEN ppnf_mgr.effective_start_date
          AND NVL(ppnf_mgr.effective_end_date, DATE '4712-12-31')
LEFT JOIN per_users pu_mgr
       ON pu_mgr.person_id = pasf.manager_id
      AND NVL(pu_mgr.active_flag, 'Y') = 'Y'
WHERE  pu.person_id = TO_NUMBER(:requester_person_id)
AND    NVL(pu.active_flag, 'Y') = 'Y'
-- AI Generated Code by Deloitte + Cursor (END)]]>
         </sql>
      </dataSet>
      <dataSet name="Requisition" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[SELECT REQUISITION_HEADER_ID FROM POR_REQUISITION_HEADERS_ALL WHERE REQUISITION_NUMBER = :req_number
--'SG1-PR-100485'
--'SG1-PR-100455']]>
         </sql>
      </dataSet>
      <dataSet name="11212" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[-- AI Generated Code by Deloitte + Cursor (BEGIN)
WITH pr_totals AS (
  SELECT
      prh.requisition_header_id,
      SUM(
        CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
             THEN NVL(prd.distribution_amount, 0) ELSE 0 END
      ) AS inv_total,
      SUM(
        CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
             THEN 0 ELSE NVL(prd.distribution_amount, 0) END
      ) AS exp_total
  FROM   por_requisition_headers_all prh
  JOIN   por_requisition_lines_all    prl ON prl.requisition_header_id = prh.requisition_header_id
  JOIN   por_req_distributions_all    prd ON prd.requisition_line_id    = prl.requisition_line_id
  JOIN   gl_code_combinations         gcc ON gcc.code_combination_id    = prd.code_combination_id
  WHERE  prh.requisition_header_id   = TO_NUMBER(:req_header_id)
  GROUP BY prh.requisition_header_id
),
pr_totals_agg AS (
  SELECT NVL(MAX(t.inv_total), 0) AS inv_total,
         NVL(MAX(t.exp_total), 0) AS exp_total
  FROM   pr_totals t
),
grade_for_person AS (
  SELECT x.person_id,
         pgt.name AS grade_lookup_code
  FROM (
    SELECT paf.person_id,
           paf.grade_id,
           ROW_NUMBER() OVER (PARTITION BY paf.person_id ORDER BY paf.effective_start_date DESC) AS rn
    FROM   per_all_assignments_m paf
    WHERE  paf.primary_assignment_flag = 'Y'
    AND    paf.effective_start_date <= TRUNC(SYSDATE)
    AND    (paf.effective_end_date IS NULL OR paf.effective_end_date >= TRUNC(SYSDATE))
  ) x
  LEFT JOIN per_grades_f pg
         ON pg.grade_id = x.grade_id
        AND pg.effective_start_date <= TRUNC(SYSDATE)
        AND (pg.effective_end_date IS NULL OR pg.effective_end_date >= TRUNC(SYSDATE))
  LEFT JOIN per_grades_f_tl pgt
         ON pgt.grade_id = x.grade_id
        AND pgt.language = NVL(USERENV('LANG'), 'US')
        AND pgt.effective_start_date <= TRUNC(SYSDATE)
        AND (pgt.effective_end_date IS NULL OR pgt.effective_end_date >= TRUNC(SYSDATE))
  WHERE  x.rn = 1
),
username_for_person AS (
  SELECT person_id,
         username
  FROM (
    SELECT u.person_id,
           u.username,
           ROW_NUMBER() OVER (PARTITION BY u.person_id ORDER BY NVL(u.last_update_date, u.creation_date) DESC) AS rn
    FROM   per_users u
    WHERE  NVL(u.active_flag, 'Y') = 'Y'
  ) z
  WHERE z.rn = 1
),
mgr_edges AS (
  SELECT DISTINCT pasf.person_id, pasf.manager_id
  FROM   per_assignment_supervisors_f pasf
  WHERE  pasf.manager_type = 'LINE_MANAGER'
  AND    pasf.effective_start_date <= TRUNC(SYSDATE)
  AND    (pasf.effective_end_date IS NULL OR pasf.effective_end_date >= TRUNC(SYSDATE))
  AND    pasf.manager_id IS NOT NULL
  AND    pasf.manager_id <> pasf.person_id
),
mgr_chain_base AS (
  SELECT CAST(1 AS NUMBER(10, 0)) AS lvl,
         TO_NUMBER(:requester_person_id) AS person_id
  FROM   dual
  UNION ALL
  SELECT CAST(LEVEL + 1 AS NUMBER(10, 0)),
         e.manager_id
  FROM   mgr_edges e
  CONNECT BY NOCYCLE PRIOR e.manager_id = e.person_id
  START WITH e.person_id = TO_NUMBER(:requester_person_id)
),
mgr_chain AS (
  SELECT m.lvl,
         m.person_id,
         ufp.username,
         COALESCE(
           NULLIF(TRIM(NVL(ppnf.first_name, '') || ' ' || NVL(ppnf.last_name, '')), ''),
           ppnf.full_name
         ) AS approver_name,
         gfp.grade_lookup_code
  FROM   mgr_chain_base m
  LEFT JOIN per_person_names_f ppnf
         ON ppnf.person_id = m.person_id
        AND ppnf.name_type = 'GLOBAL'
        AND ppnf.effective_start_date <= TRUNC(SYSDATE)
        AND (ppnf.effective_end_date IS NULL OR ppnf.effective_end_date >= TRUNC(SYSDATE))
  LEFT JOIN username_for_person ufp ON ufp.person_id = m.person_id
  LEFT JOIN grade_for_person gfp ON gfp.person_id = m.person_id
),
scored AS (
  SELECT
      mc.lvl,
      mc.person_id,
      mc.username,
      mc.approver_name,
      mc.grade_lookup_code,
      CASE
        WHEN TRIM(ffv.description) IS NOT NULL
         AND REGEXP_LIKE(TRIM(ffv.description), '^-?[0-9]+(\.[0-9]+)?$')
        THEN TO_NUMBER(TRIM(ffv.description))
      END AS exp_cap,
      CASE
        WHEN TRIM(ffv.tag) IS NOT NULL
         AND REGEXP_LIKE(TRIM(ffv.tag), '^-?[0-9]+(\.[0-9]+)?$')
        THEN TO_NUMBER(TRIM(ffv.tag))
      END AS inv_cap,
      CASE
        WHEN mc.grade_lookup_code IS NULL OR ffv.lookup_code IS NULL
        THEN 0
        WHEN NVL(pt.exp_total, 0) = 0 AND NVL(pt.inv_total, 0) = 0
        THEN 0
        WHEN NVL(pt.exp_total, 0) > 0 AND TRIM(ffv.description) IS NOT NULL
         AND NOT REGEXP_LIKE(TRIM(ffv.description), '^-?[0-9]+(\.[0-9]+)?$')
        THEN 0
        WHEN NVL(pt.inv_total, 0) > 0 AND TRIM(ffv.tag) IS NOT NULL
         AND NOT REGEXP_LIKE(TRIM(ffv.tag), '^-?[0-9]+(\.[0-9]+)?$')
        THEN 0
        WHEN NVL(pt.exp_total, 0) > 0 AND NVL(pt.inv_total, 0) > 0
        THEN CASE
               WHEN TRIM(ffv.description) IS NULL OR TRIM(ffv.tag) IS NULL
               THEN 0
               WHEN pt.exp_total <= TO_NUMBER(TRIM(ffv.description))
                AND pt.inv_total <= TO_NUMBER(TRIM(ffv.tag))
               THEN 1 ELSE 0
             END
        WHEN NVL(pt.exp_total, 0) > 0 AND NVL(pt.inv_total, 0) = 0
        THEN CASE
               WHEN TRIM(ffv.description) IS NULL THEN 0
               WHEN pt.exp_total <= TO_NUMBER(TRIM(ffv.description))
               THEN 1 ELSE 0
             END
        WHEN NVL(pt.exp_total, 0) = 0 AND NVL(pt.inv_total, 0) > 0
        THEN CASE
               WHEN TRIM(ffv.tag) IS NULL THEN 0
               WHEN pt.inv_total <= TO_NUMBER(TRIM(ffv.tag))
               THEN 1 ELSE 0
             END
        ELSE 0
      END AS can_approve,
      pt.inv_total,
      pt.exp_total
  FROM   mgr_chain mc
  CROSS JOIN pr_totals_agg pt
  LEFT JOIN fnd_lookup_values_vl ffv
         ON ffv.lookup_type  = 'TER_SIGN_APPROVAL_LIMIT'
        AND ffv.enabled_flag = 'Y'
        AND TRIM(ffv.lookup_code) = TRIM(mc.grade_lookup_code)
        AND NVL(ffv.start_date_active, TRUNC(SYSDATE)) <= TRUNC(SYSDATE)
        AND (ffv.end_date_active IS NULL OR ffv.end_date_active >= TRUNC(SYSDATE))
)
SELECT *
FROM   scored
WHERE  can_approve = 0
ORDER BY lvl
-- AI Generated Code by Deloitte + Cursor (END)]]>
         </sql>
      </dataSet>
      <dataSet name="REQ_MAIN" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[SELECT
      prh.requisition_header_id,
      SUM(
        CASE
          WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
          THEN NVL(prd.distribution_amount, 0)
          ELSE 0
        END
      ) AS inv_total,
      SUM(
        CASE
          WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
          THEN 0
          ELSE NVL(prd.distribution_amount, 0)
        END
      ) AS exp_total
  FROM   por_requisition_headers_all prh
  JOIN   por_requisition_lines_all    prl ON prl.requisition_header_id = prh.requisition_header_id
  JOIN   por_req_distributions_all    prd ON prd.requisition_line_id    = prl.requisition_line_id
  JOIN   gl_code_combinations         gcc ON gcc.code_combination_id    = prd.code_combination_id
  WHERE  prh.requisition_header_id   = TO_NUMBER(:req_header_id)
  GROUP BY prh.requisition_header_id]]>
         </sql>
      </dataSet>
      <dataSet name="Overriding Query" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[SELECT 
    prha.requisition_number,
    prha.document_status,
    prha.preparer_id,
    prha.overriding_approver_id,
    ppnf.display_name AS overriding_approver_name,
    prha.creation_date
FROM 
    por_requisition_headers_all prha
LEFT JOIN 
    per_person_names_f ppnf ON prha.overriding_approver_id = ppnf.person_id
    AND ppnf.name_type = 'GLOBAL'
    -- Ensures you retrieve the name active on the creation date
    AND TRUNC(prha.creation_date) BETWEEN ppnf.effective_start_date AND ppnf.effective_end_date
WHERE 
    prha.requisition_header_id = 300000009974811]]>
         </sql>
      </dataSet>
      <dataSet name="new main" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[-- AI Generated Code by Deloitte + Cursor (BEGIN)
WITH req_hdr AS (
  SELECT prh.requisition_header_id,
         prh.overriding_approver_id,
         prh.preparer_id
  FROM   por_requisition_headers_all prh
  WHERE  prh.requisition_header_id = TO_NUMBER(:req_header_id)
),
root_ctx AS (
  SELECT NVL(rh.overriding_approver_id, rh.preparer_id) AS root_person_id
  FROM   req_hdr rh
),
pr_totals AS (
  SELECT
      prh.requisition_header_id,
      SUM(
        CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
             THEN NVL(prd.distribution_amount, 0) ELSE 0 END
      ) AS inv_total,
      SUM(
        CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
             THEN 0 ELSE NVL(prd.distribution_amount, 0) END
      ) AS exp_total
  FROM   por_requisition_headers_all prh
  JOIN   por_requisition_lines_all    prl ON prl.requisition_header_id = prh.requisition_header_id
  JOIN   por_req_distributions_all    prd ON prd.requisition_line_id    = prl.requisition_line_id
  JOIN   gl_code_combinations         gcc ON gcc.code_combination_id    = prd.code_combination_id
  WHERE  prh.requisition_header_id   = TO_NUMBER(:req_header_id)
  GROUP BY prh.requisition_header_id
),
pr_totals_agg AS (
  SELECT NVL(MAX(t.inv_total), 0) AS inv_total,
         NVL(MAX(t.exp_total), 0) AS exp_total
  FROM   pr_totals t
),
grade_for_person AS (
  SELECT x.person_id,
         pgt.name AS grade_lookup_code
  FROM (
    SELECT paf.person_id,
           paf.grade_id,
           ROW_NUMBER() OVER (
             PARTITION BY paf.person_id
             ORDER BY paf.effective_start_date DESC
           ) AS rn
    FROM   per_all_assignments_m paf
    WHERE  paf.primary_assignment_flag = 'Y'
    AND    paf.effective_start_date <= TRUNC(SYSDATE)
    AND    (paf.effective_end_date IS NULL OR paf.effective_end_date >= TRUNC(SYSDATE))
  ) x
  LEFT JOIN per_grades_f pg
         ON pg.grade_id = x.grade_id
        AND pg.effective_start_date <= TRUNC(SYSDATE)
        AND (pg.effective_end_date IS NULL OR pg.effective_end_date >= TRUNC(SYSDATE))
  LEFT JOIN per_grades_f_tl pgt
         ON pgt.grade_id = x.grade_id
        AND pgt.language = NVL(USERENV('LANG'), 'US')
        AND pgt.effective_start_date <= TRUNC(SYSDATE)
        AND (pgt.effective_end_date IS NULL OR pgt.effective_end_date >= TRUNC(SYSDATE))
  WHERE  x.rn = 1
),
username_for_person AS (
  SELECT person_id,
         username
  FROM (
    SELECT u.person_id,
           u.username,
           ROW_NUMBER() OVER (
             PARTITION BY u.person_id
             ORDER BY NVL(u.last_update_date, u.creation_date) DESC
           ) AS rn
    FROM   per_users u
    WHERE  NVL(u.active_flag, 'Y') = 'Y'
  ) z
  WHERE z.rn = 1
),
mgr_edges AS (
  SELECT DISTINCT
         pasf.person_id,
         pasf.manager_id
  FROM   per_assignment_supervisors_f pasf
  WHERE  pasf.manager_type = 'LINE_MANAGER'
  AND    pasf.effective_start_date <= TRUNC(SYSDATE)
  AND    (pasf.effective_end_date IS NULL OR pasf.effective_end_date >= TRUNC(SYSDATE))
  AND    pasf.manager_id IS NOT NULL
  AND    pasf.manager_id <> pasf.person_id
),
mgr_chain_base AS (
  SELECT CAST(1 AS NUMBER(10, 0)) AS lvl,
         rc.root_person_id AS person_id
  FROM   root_ctx rc
  UNION ALL
  SELECT CAST(LEVEL + 1 AS NUMBER(10, 0)) AS lvl,
         e.manager_id AS person_id
  FROM   mgr_edges e
  CONNECT BY NOCYCLE PRIOR e.manager_id = e.person_id
  START WITH e.person_id = (SELECT root_person_id FROM root_ctx)
),
mgr_chain AS (
  SELECT m.lvl,
         m.person_id,
         ufp.username,
         COALESCE(
           NULLIF(TRIM(NVL(ppnf.first_name, '') || ' ' || NVL(ppnf.last_name, '')), ''),
           ppnf.full_name
         ) AS approver_name,
         gfp.grade_lookup_code
  FROM   mgr_chain_base m
  LEFT JOIN per_person_names_f ppnf
         ON ppnf.person_id = m.person_id
        AND ppnf.name_type = 'GLOBAL'
        AND ppnf.effective_start_date <= TRUNC(SYSDATE)
        AND (ppnf.effective_end_date IS NULL OR ppnf.effective_end_date >= TRUNC(SYSDATE))
  LEFT JOIN username_for_person ufp ON ufp.person_id = m.person_id
  LEFT JOIN grade_for_person gfp     ON gfp.person_id = m.person_id
),
scored AS (
  SELECT
      mc.lvl,
      mc.person_id,
      mc.username,
      mc.approver_name,
      mc.grade_lookup_code,
      CASE
        WHEN TRIM(ffv.description) IS NOT NULL
         AND REGEXP_LIKE(TRIM(ffv.description), '^-?[0-9]+(\.[0-9]+)?$')
        THEN TO_NUMBER(TRIM(ffv.description))
      END AS exp_cap,
      CASE
        WHEN TRIM(ffv.tag) IS NOT NULL
         AND REGEXP_LIKE(TRIM(ffv.tag), '^-?[0-9]+(\.[0-9]+)?$')
        THEN TO_NUMBER(TRIM(ffv.tag))
      END AS inv_cap,
      CASE
        WHEN mc.grade_lookup_code IS NULL OR ffv.lookup_code IS NULL
        THEN 0
        WHEN NVL(pt.exp_total, 0) = 0 AND NVL(pt.inv_total, 0) = 0
        THEN 0
        WHEN NVL(pt.exp_total, 0) > 0 AND TRIM(ffv.description) IS NOT NULL
         AND NOT REGEXP_LIKE(TRIM(ffv.description), '^-?[0-9]+(\.[0-9]+)?$')
        THEN 0
        WHEN NVL(pt.inv_total, 0) > 0 AND TRIM(ffv.tag) IS NOT NULL
         AND NOT REGEXP_LIKE(TRIM(ffv.tag), '^-?[0-9]+(\.[0-9]+)?$')
        THEN 0
        WHEN NVL(pt.exp_total, 0) > 0 AND NVL(pt.inv_total, 0) > 0
        THEN CASE
               WHEN TRIM(ffv.description) IS NULL OR TRIM(ffv.tag) IS NULL
               THEN 0
               WHEN pt.exp_total <= TO_NUMBER(TRIM(ffv.description))
                AND pt.inv_total <= TO_NUMBER(TRIM(ffv.tag))
               THEN 1 ELSE 0
             END
        WHEN NVL(pt.exp_total, 0) > 0 AND NVL(pt.inv_total, 0) = 0
        THEN CASE
               WHEN TRIM(ffv.description) IS NULL THEN 0
               WHEN pt.exp_total <= TO_NUMBER(TRIM(ffv.description))
               THEN 1 ELSE 0
             END
        WHEN NVL(pt.exp_total, 0) = 0 AND NVL(pt.inv_total, 0) > 0
        THEN CASE
               WHEN TRIM(ffv.tag) IS NULL THEN 0
               WHEN pt.inv_total <= TO_NUMBER(TRIM(ffv.tag))
               THEN 1 ELSE 0
             END
        ELSE 0
      END AS can_approve
  FROM   mgr_chain mc
  CROSS JOIN pr_totals_agg pt
  LEFT JOIN fnd_lookup_values_vl ffv
         ON ffv.lookup_type  = 'TER_SIGN_APPROVAL_LIMIT'
        AND ffv.enabled_flag = 'Y'
        AND TRIM(ffv.lookup_code) = TRIM(mc.grade_lookup_code)
        AND NVL(ffv.start_date_active, TRUNC(SYSDATE)) <= TRUNC(SYSDATE)
        AND (ffv.end_date_active IS NULL OR ffv.end_date_active >= TRUNC(SYSDATE))
),
/* Dynamic: first level whose LOOKUP cap (not requisition total) is >= 2M */
first_high_cap AS (
  SELECT MIN(s.lvl) AS first_high_cap_lvl
  FROM   scored s
  CROSS JOIN pr_totals_agg pt
  WHERE  (   NVL(pt.exp_total, 0) > 0
         AND NVL(pt.inv_total, 0) > 0
         AND GREATEST(NVL(s.exp_cap, 0), NVL(s.inv_cap, 0)) >= 2000000
         )
      OR (   NVL(pt.exp_total, 0) > 0
         AND NVL(pt.inv_total, 0) = 0
         AND NVL(s.exp_cap, 0) >= 2000000
         )
      OR (   NVL(pt.exp_total, 0) = 0
         AND NVL(pt.inv_total, 0) > 0
         AND NVL(s.inv_cap, 0) >= 2000000
         )
),
/* Dynamic: first level who can approve per exp / inv / both rules */
first_approver AS (
  SELECT MIN(s.lvl) AS stop_lvl
  FROM   scored s
  WHERE  s.can_approve = 1
),
/* How far up the chain to include (whichever stops you first) */
chain_limit AS (
  SELECT
      fa.stop_lvl,
      fhc.first_high_cap_lvl,
      CASE
        WHEN fhc.first_high_cap_lvl IS NOT NULL
         AND fa.stop_lvl IS NOT NULL
        THEN LEAST(fa.stop_lvl, fhc.first_high_cap_lvl - 1)
        WHEN fhc.first_high_cap_lvl IS NOT NULL
        THEN fhc.first_high_cap_lvl - 1
        WHEN fa.stop_lvl IS NOT NULL
        THEN fa.stop_lvl
      END AS max_lvl
  FROM   first_approver fa
  FULL OUTER JOIN first_high_cap fhc ON 1 = 1
),
hierarchy_result AS (
  SELECT LISTAGG(NVL(s.username, s.approver_name), ',')
           WITHIN GROUP (ORDER BY s.lvl) AS approver_csv
  FROM   scored s
  CROSS JOIN chain_limit cl
  WHERE  cl.max_lvl IS NOT NULL
  AND    s.lvl <= cl.max_lvl
)
SELECT CASE
         WHEN NVL(pt.exp_total, 0) = 0
          AND NVL(pt.inv_total, 0) = 0
         THEN CAST(NULL AS VARCHAR2(4000))
         ELSE hr.approver_csv
       END AS new_approver_csv
FROM   pr_totals_agg pt
LEFT JOIN hierarchy_result hr
       ON (NVL(pt.exp_total, 0) > 0 OR NVL(pt.inv_total, 0) > 0)
-- AI Generated Code by Deloitte + Cursor (END)]]>
         </sql>
      </dataSet>
   </dataSets>
   <output rootName="DATA_DS" uniqueRowName="false">
