            </group>
            <group name="G_7" label="G_7" source="11212">
               <element name="LVL" value="LVL" label="LVL" dataType="xsd:long" breakOrder="" fieldOrder="1"/>
               <element name="PERSON_ID" value="PERSON_ID" label="PERSON_ID" dataType="xsd:double" breakOrder="" fieldOrder="2"/>
               <element name="USERNAME" value="USERNAME" label="USERNAME" dataType="xsd:string" breakOrder="" fieldOrder="3"/>
               <element name="APPROVER_NAME" value="APPROVER_NAME" label="APPROVER_NAME" dataType="xsd:string" breakOrder="" fieldOrder="4"/>
               <element name="GRADE_LOOKUP_CODE" value="GRADE_LOOKUP_CODE" label="GRADE_LOOKUP_CODE" dataType="xsd:string" breakOrder="" fieldOrder="5"/>
               <element name="EXP_CAP" value="EXP_CAP" label="EXP_CAP" dataType="xsd:double" breakOrder="" fieldOrder="6"/>
               <element name="INV_CAP" value="INV_CAP" label="INV_CAP" dataType="xsd:double" breakOrder="" fieldOrder="7"/>
