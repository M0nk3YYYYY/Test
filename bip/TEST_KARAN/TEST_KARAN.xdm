<?xml version = '1.0' encoding = 'utf-8'?>
<dataModel xmlns="http://xmlns.oracle.com/oxp/xmlp" version="2.1" xmlns:xdm="http://xmlns.oracle.com/oxp/xmlp" xmlns:xsd="http://wwww.w3.org/2001/XMLSchema" defaultDataSourceRef="Oracle BI EE">
   <dataProperties>
      <property name="include_parameters" value="true"/>
      <property name="include_null_Element" value="false"/>
      <property name="include_rowsettag" value="false"/>
      <property name="exclude_tags_for_lob" value="false"/>
      <property name="EXCLUDE_LINE_FEED_AND_CARRIAGE_RETURN_FOR_LOB" value="false"/>
      <property name="xml_tag_case" value="upper"/>
      <property name="generate_output_format" value="xml"/>
      <property name="enforce_validation_status" value="true"/>
      <property name="optimize_query_executions" value="false"/>
      <property name="enable_xml_chunks" value=""/>
      <property name="sql_monitor_report_generated" value="false"/>
   </dataProperties>
   <dataSets>
      <dataSet name="main" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[WITH pr_totals AS (
  SELECT
      prh.requisition_header_id,
      SUM(
        CASE
          WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
          THEN NVL(prd.distribution_amount, 0)
          ELSE 0
        END
      ) AS inv_total,
      SUM(
        CASE
          WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
          THEN 0
          ELSE NVL(prd.distribution_amount, 0)
        END
      ) AS exp_total
  FROM   por_requisition_headers_all prh
  JOIN   por_requisition_lines_all    prl ON prl.requisition_header_id = prh.requisition_header_id
  JOIN   por_req_distributions_all    prd ON prd.requisition_line_id    = prl.requisition_line_id
  JOIN   gl_code_combinations         gcc ON gcc.code_combination_id    = prd.code_combination_id
  WHERE  prh.requisition_header_id   = TO_NUMBER(:req_header_id)
  GROUP BY prh.requisition_header_id
),
grade_for_person AS (
  SELECT x.person_id,
         pgt.name AS grade_lookup_code
  FROM (
    SELECT paf.person_id,
           paf.grade_id,
           ROW_NUMBER() OVER (
             PARTITION BY paf.person_id
             ORDER BY paf.effective_start_date DESC
           ) AS rn
    FROM   per_all_assignments_m paf
    WHERE  paf.primary_assignment_flag = 'Y'
    AND    TRUNC(SYSDATE) BETWEEN paf.effective_start_date
                              AND NVL(paf.effective_end_date, DATE '4712-12-31')
  ) x
  LEFT JOIN per_grades_f pg
         ON pg.grade_id = x.grade_id
        AND TRUNC(SYSDATE) BETWEEN pg.effective_start_date
                               AND NVL(pg.effective_end_date, DATE '4712-12-31')
  LEFT JOIN per_grades_f_tl pgt
         ON pgt.grade_id = x.grade_id
        AND pgt.language = NVL(USERENV('LANG'), 'US')
        AND TRUNC(SYSDATE) BETWEEN pgt.effective_start_date
                               AND NVL(pgt.effective_end_date, DATE '4712-12-31')
  WHERE  x.rn = 1
),
username_for_person AS (
  SELECT person_id,
         username
  FROM (
    SELECT u.person_id,
           u.username,
           ROW_NUMBER() OVER (
             PARTITION BY u.person_id
             ORDER BY NVL(u.last_update_date, u.creation_date) DESC
           ) AS rn
    FROM   per_users u
    WHERE  NVL(u.active_flag, 'Y') = 'Y'
  ) z
  WHERE z.rn = 1
),
mgr_edges AS (
  SELECT DISTINCT
         pasf.person_id,
         pasf.manager_id
  FROM   per_assignment_supervisors_f pasf
  WHERE  pasf.manager_type = 'LINE_MANAGER'
  AND    TRUNC(SYSDATE) BETWEEN pasf.effective_start_date
                            AND NVL(pasf.effective_end_date, DATE '4712-12-31')
  AND    pasf.manager_id IS NOT NULL
  AND    pasf.manager_id <> pasf.person_id
),
mgr_chain_base AS (
  SELECT CAST(1 AS NUMBER(10, 0)) AS lvl,
         TO_NUMBER(:requester_person_id) AS person_id
  FROM   dual
  UNION ALL
  SELECT CAST(LEVEL + 1 AS NUMBER(10, 0)) AS lvl,
         e.manager_id AS person_id
  FROM   mgr_edges e
  CONNECT BY NOCYCLE PRIOR e.manager_id = e.person_id
  START WITH e.person_id = TO_NUMBER(:requester_person_id)
),
mgr_chain AS (
  SELECT m.lvl,
         m.person_id,
         ufp.username,
         COALESCE(
           NULLIF(TRIM(NVL(ppnf.first_name, '') || ' ' || NVL(ppnf.last_name, '')), ''),
           ppnf.full_name
         ) AS approver_name,
         gfp.grade_lookup_code
  FROM   mgr_chain_base m
  LEFT JOIN per_person_names_f ppnf
         ON ppnf.person_id = m.person_id
        AND ppnf.name_type = 'GLOBAL'
        AND TRUNC(SYSDATE) BETWEEN ppnf.effective_start_date
                               AND NVL(ppnf.effective_end_date, DATE '4712-12-31')
  LEFT JOIN username_for_person ufp ON ufp.person_id = m.person_id
  LEFT JOIN grade_for_person gfp     ON gfp.person_id = m.person_id
),
scored AS (
  SELECT
      mc.lvl,
      mc.person_id,
      mc.username,
      mc.approver_name,
      mc.grade_lookup_code,
      TO_NUMBER(ffv.description) AS exp_cap,
      TO_NUMBER(ffv.tag)         AS inv_cap,
      CASE
        WHEN ffv.lookup_code IS NULL
          OR mc.grade_lookup_code IS NULL
        THEN 0
        WHEN pt.exp_total <= TO_NUMBER(ffv.description)
         AND pt.inv_total <= TO_NUMBER(ffv.tag)
        THEN 1
        ELSE 0
      END AS can_approve
  FROM   mgr_chain mc
  CROSS JOIN pr_totals pt
  LEFT JOIN fnd_lookup_values_vl ffv
         ON ffv.lookup_type  = 'TER_SIGN_APPROVAL_LIMIT'
        AND ffv.enabled_flag = 'Y'
        AND ffv.lookup_code  = mc.grade_lookup_code
        AND TRUNC(SYSDATE) BETWEEN NVL(ffv.start_date_active, TRUNC(SYSDATE))
                               AND NVL(ffv.end_date_active,   TRUNC(SYSDATE))
),
first_ok AS (
  SELECT MIN(lvl) AS stop_lvl
  FROM   scored
  WHERE  can_approve = 1
)
SELECT LISTAGG(s.approver_name, ',') WITHIN GROUP (ORDER BY s.lvl) AS approver_csv
FROM   scored s
CROSS JOIN first_ok fo
WHERE  s.lvl <= fo.stop_lvl
AND    fo.stop_lvl IS NOT NULL]]>
         </sql>
      </dataSet>
      <dataSet name="Query 2" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[-- AI Generated Code by Deloitte + Cursor (BEGIN)
WITH mgr_edges AS (
  SELECT DISTINCT mdn.person_id, mdn.manager_id
  FROM   per_manager_hrchy_dn mdn
  WHERE  mdn.manager_type = 'LINE_MANAGER'
  AND    mdn.primary_manager_flag = 'Y'
