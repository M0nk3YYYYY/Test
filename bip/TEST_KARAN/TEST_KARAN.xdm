         <dataStructure tagName="DATA_DS">
            <group name="G_1" label="G_1" source="main">
               <element name="APPROVER_CSV" value="APPROVER_CSV" label="APPROVER_CSV" dataType="xsd:string" breakOrder="" fieldOrder="1"/>
            </group>
            <group name="G_2" label="G_2" source="Query 2">
               <element name="LVL" value="LVL" label="LVL" dataType="xsd:long" breakOrder="" fieldOrder="1"/>
               <element name="PERSON_ID" value="PERSON_ID" label="PERSON_ID" dataType="xsd:double" breakOrder="" fieldOrder="2"/>
