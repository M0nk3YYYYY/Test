<?xml version = '1.0' encoding = 'utf-8'?>
<dataModel xmlns="http://xmlns.oracle.com/oxp/xmlp" version="2.1" xmlns:xdm="http://xmlns.oracle.com/oxp/xmlp" xmlns:xsd="http://wwww.w3.org/2001/XMLSchema" defaultDataSourceRef="Oracle BI EE">
   <dataProperties>
      <property name="include_parameters" value="true"/>
      <property name="include_null_Element" value="false"/>
      <property name="include_rowsettag" value="false"/>
      <property name="exclude_tags_for_lob" value="false"/>
      <property name="EXCLUDE_LINE_FEED_AND_CARRIAGE_RETURN_FOR_LOB" value="false"/>
      <property name="xml_tag_case" value="upper"/>
      <property name="enforce_validation_status" value="true"/>
      <property name="optimize_query_executions" value="false"/>
      <property name="enable_xml_chunks" value=""/>
      <property name="sql_monitor_report_generated" value="false"/>
   </dataProperties>
   <dataSets>
      <dataSet name="1" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[SELECT prh.requisition_header_id,
       prh.requisition_number,
       prh.preparer_id,
       prh.overriding_approver_id,
       NVL(prh.overriding_approver_id, prh.preparer_id) AS root_person_id_table
FROM   por_requisition_headers_all prh
WHERE  prh.requisition_header_id = TO_NUMBER(:req_header_id)]]>
         </sql>
      </dataSet>
      <dataSet name="1b" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[SELECT TO_NUMBER(:preparer_person_id) AS preparer_bind,
       prh.preparer_id AS preparer_on_header,
       CASE WHEN TO_NUMBER(:preparer_person_id) = prh.preparer_id THEN 'MATCH' ELSE 'MISMATCH' END AS bind_check
FROM   por_requisition_headers_all prh
WHERE  prh.requisition_header_id = TO_NUMBER(:req_header_id)]]>
         </sql>
      </dataSet>
      <dataSet name="9" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[WITH req_hdr AS (
  SELECT NVL(prh.overriding_approver_id, prh.preparer_id) AS root_table,
         prh.preparer_id
  FROM por_requisition_headers_all prh
  WHERE prh.requisition_header_id = TO_NUMBER(:req_header_id)
)
SELECT rh.root_table,
       TO_NUMBER(:preparer_person_id) AS root_bind_preparer,
       CASE WHEN rh.root_table = TO_NUMBER(:preparer_person_id) THEN 'SAME' ELSE 'DIFFERENT' END AS compare_root
FROM req_hdr rh]]>
         </sql>
      </dataSet>
      <dataSet name="2" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[SELECT prh.requisition_header_id,
       SUM(CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
                THEN NVL(prd.distribution_amount, 0) ELSE 0 END) AS inv_total,
       SUM(CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
                THEN 0 ELSE NVL(prd.distribution_amount, 0) END) AS exp_total
FROM   por_requisition_headers_all prh
JOIN   por_requisition_lines_all    prl ON prl.requisition_header_id = prh.requisition_header_id
JOIN   por_req_distributions_all    prd ON prd.requisition_line_id    = prl.requisition_line_id
JOIN   gl_code_combinations         gcc ON gcc.code_combination_id    = prd.code_combination_id
WHERE  prh.requisition_header_id = TO_NUMBER(:req_header_id)
GROUP BY prh.requisition_header_id]]>
         </sql>
      </dataSet>
      <dataSet name="3" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[WITH pr_totals AS (
  SELECT prh.requisition_header_id,
         SUM(CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
                  THEN NVL(prd.distribution_amount, 0) ELSE 0 END) AS inv_total,
         SUM(CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
                  THEN 0 ELSE NVL(prd.distribution_amount, 0) END) AS exp_total
  FROM   por_requisition_headers_all prh
  JOIN   por_requisition_lines_all    prl ON prl.requisition_header_id = prh.requisition_header_id
  JOIN   por_req_distributions_all    prd ON prd.requisition_line_id    = prl.requisition_line_id
  JOIN   gl_code_combinations         gcc ON gcc.code_combination_id    = prd.code_combination_id
  WHERE  prh.requisition_header_id = TO_NUMBER(:req_header_id)
  GROUP BY prh.requisition_header_id
)
SELECT NVL(MAX(t.inv_total), 0) AS inv_total_agg,
       NVL(MAX(t.exp_total), 0) AS exp_total_agg
FROM   pr_totals t]]>
         </sql>
      </dataSet>
      <dataSet name="4" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[WITH req_hdr AS (
  SELECT prh.overriding_approver_id, prh.preparer_id
  FROM   por_requisition_headers_all prh
  WHERE  prh.requisition_header_id = TO_NUMBER(:req_header_id)
),
root_ctx AS (
  SELECT NVL(rh.overriding_approver_id, rh.preparer_id) AS root_person_id
  FROM   req_hdr rh
),
mgr_edges AS (
  SELECT DISTINCT pasf.person_id, pasf.manager_id
  FROM   per_assignment_supervisors_f pasf
  WHERE  pasf.manager_type = 'LINE_MANAGER'
  AND    pasf.effective_start_date <= TRUNC(SYSDATE)
  AND    (pasf.effective_end_date IS NULL OR pasf.effective_end_date >= TRUNC(SYSDATE))
  AND    pasf.manager_id IS NOT NULL
  AND    pasf.manager_id <> pasf.person_id
),
mgr_chain_base AS (
  SELECT CAST(1 AS NUMBER(10, 0)) AS lvl, rc.root_person_id AS person_id
  FROM   root_ctx rc
  UNION ALL
  SELECT CAST(LEVEL + 1 AS NUMBER(10, 0)), e.manager_id
  FROM   mgr_edges e
  CONNECT BY NOCYCLE PRIOR e.manager_id = e.person_id
  START WITH e.person_id = (SELECT root_person_id FROM root_ctx)
)
SELECT COUNT(*) AS chain_rows, MIN(lvl) AS min_lvl, MAX(lvl) AS max_lvl
FROM   mgr_chain_base]]>
         </sql>
      </dataSet>
      <dataSet name="5" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[SELECT ffv.lookup_code,
       ffv.meaning,
       ffv.description,
       ffv.tag,
       ffv.enabled_flag,
       ffv.start_date_active,
       ffv.end_date_active,
       COUNT(*) OVER () AS total_matching_rows
FROM   fnd_lookup_values_vl ffv
WHERE  ffv.lookup_type = 'TER_SIGN_APPROVAL_LIMIT'
AND    ffv.enabled_flag = 'Y'
AND    TRIM(ffv.lookup_code) = TRIM(:one_grade_lookup_code)
AND    NVL(ffv.start_date_active, TRUNC(SYSDATE)) <= TRUNC(SYSDATE)
AND    (ffv.end_date_active IS NULL OR ffv.end_date_active >= TRUNC(SYSDATE))
ORDER BY  ffv.lookup_code]]>
         </sql>
      </dataSet>
      <dataSet name="6" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[WITH req_hdr AS (
  SELECT prh.overriding_approver_id, prh.preparer_id
  FROM   por_requisition_headers_all prh
  WHERE  prh.requisition_header_id = TO_NUMBER(:req_header_id)
),
root_ctx AS (
  SELECT NVL(rh.overriding_approver_id, rh.preparer_id) AS root_person_id FROM req_hdr rh
),
pr_totals AS (
  SELECT prh.requisition_header_id,
         SUM(CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
                  THEN NVL(prd.distribution_amount, 0) ELSE 0 END) inv_total,
         SUM(CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
                  THEN 0 ELSE NVL(prd.distribution_amount, 0) END) exp_total
  FROM por_requisition_headers_all prh
  JOIN por_requisition_lines_all prl ON prl.requisition_header_id = prh.requisition_header_id
  JOIN por_req_distributions_all prd ON prd.requisition_line_id = prl.requisition_line_id
  JOIN gl_code_combinations gcc ON gcc.code_combination_id = prd.code_combination_id
  WHERE prh.requisition_header_id = TO_NUMBER(:req_header_id)
  GROUP BY prh.requisition_header_id
),
pr_totals_agg AS (
  SELECT NVL(MAX(t.inv_total),0) inv_total, NVL(MAX(t.exp_total),0) exp_total FROM pr_totals t
),
grade_for_person AS (
  SELECT x.person_id, pgt.name AS grade_lookup_code
  FROM (
    SELECT paf.person_id, paf.grade_id,
           ROW_NUMBER() OVER (PARTITION BY paf.person_id ORDER BY paf.effective_start_date DESC) rn
    FROM per_all_assignments_m paf
    WHERE paf.primary_assignment_flag = 'Y'
    AND paf.effective_start_date <= TRUNC(SYSDATE)
    AND (paf.effective_end_date IS NULL OR paf.effective_end_date >= TRUNC(SYSDATE))
  ) x
  LEFT JOIN per_grades_f pg ON pg.grade_id = x.grade_id
    AND pg.effective_start_date <= TRUNC(SYSDATE)
    AND (pg.effective_end_date IS NULL OR pg.effective_end_date >= TRUNC(SYSDATE))
  LEFT JOIN per_grades_f_tl pgt ON pgt.grade_id = x.grade_id
    AND pgt.language = NVL(USERENV('LANG'), 'US')
    AND pgt.effective_start_date <= TRUNC(SYSDATE)
    AND (pgt.effective_end_date IS NULL OR pgt.effective_end_date >= TRUNC(SYSDATE))
  WHERE x.rn = 1
),
username_for_person AS (
  SELECT person_id, username FROM (
    SELECT u.person_id, u.username,
           ROW_NUMBER() OVER (PARTITION BY u.person_id ORDER BY NVL(u.last_update_date,u.creation_date) DESC) rn
    FROM per_users u WHERE NVL(u.active_flag,'Y') = 'Y'
  ) z WHERE z.rn = 1
),
mgr_edges AS (
  SELECT DISTINCT pasf.person_id, pasf.manager_id
  FROM per_assignment_supervisors_f pasf
  WHERE pasf.manager_type = 'LINE_MANAGER'
  AND pasf.effective_start_date <= TRUNC(SYSDATE)
  AND (pasf.effective_end_date IS NULL OR pasf.effective_end_date >= TRUNC(SYSDATE))
  AND pasf.manager_id IS NOT NULL AND pasf.manager_id <> pasf.person_id
),
mgr_chain_base AS (
  SELECT CAST(1 AS NUMBER(10,0)) lvl, rc.root_person_id person_id FROM root_ctx rc
  UNION ALL
  SELECT CAST(LEVEL+1 AS NUMBER(10,0)), e.manager_id
  FROM mgr_edges e
  CONNECT BY NOCYCLE PRIOR e.manager_id = e.person_id
  START WITH e.person_id = (SELECT root_person_id FROM root_ctx)
),
mgr_chain AS (
  SELECT m.lvl, m.person_id, ufp.username,
         COALESCE(NULLIF(TRIM(NVL(ppnf.first_name,'')||' '||NVL(ppnf.last_name,'')),''),
                  ppnf.full_name) approver_name,
         gfp.grade_lookup_code
  FROM mgr_chain_base m
  LEFT JOIN per_person_names_f ppnf ON ppnf.person_id = m.person_id
    AND ppnf.name_type = 'GLOBAL'
    AND ppnf.effective_start_date <= TRUNC(SYSDATE)
    AND (ppnf.effective_end_date IS NULL OR ppnf.effective_end_date >= TRUNC(SYSDATE))
  LEFT JOIN username_for_person ufp ON ufp.person_id = m.person_id
  LEFT JOIN grade_for_person gfp ON gfp.person_id = m.person_id
),
scored AS (
  SELECT mc.lvl, mc.person_id, mc.username, mc.approver_name, mc.grade_lookup_code,
         CASE WHEN TRIM(ffv.description) IS NOT NULL
               AND REGEXP_LIKE(TRIM(ffv.description), '^-?[0-9]+(\.[0-9]+)?$')
              THEN TO_NUMBER(TRIM(ffv.description)) END exp_cap,
         CASE WHEN TRIM(ffv.tag) IS NOT NULL
               AND REGEXP_LIKE(TRIM(ffv.tag), '^-?[0-9]+(\.[0-9]+)?$')
              THEN TO_NUMBER(TRIM(ffv.tag)) END inv_cap,
         CASE
           WHEN mc.grade_lookup_code IS NULL OR ffv.lookup_code IS NULL THEN 0
           WHEN NVL(pt.exp_total,0) = 0 AND NVL(pt.inv_total,0) = 0 THEN 0
           WHEN NVL(pt.exp_total,0) > 0 AND TRIM(ffv.description) IS NOT NULL
            AND NOT REGEXP_LIKE(TRIM(ffv.description), '^-?[0-9]+(\.[0-9]+)?$') THEN 0
           WHEN NVL(pt.inv_total,0) > 0 AND TRIM(ffv.tag) IS NOT NULL
            AND NOT REGEXP_LIKE(TRIM(ffv.tag), '^-?[0-9]+(\.[0-9]+)?$') THEN 0
           WHEN NVL(pt.exp_total,0) > 0 AND NVL(pt.inv_total,0) > 0 THEN CASE
                  WHEN TRIM(ffv.description) IS NULL OR TRIM(ffv.tag) IS NULL THEN 0
                  WHEN pt.exp_total <= TO_NUMBER(TRIM(ffv.description))
                   AND pt.inv_total <= TO_NUMBER(TRIM(ffv.tag)) THEN 1 ELSE 0 END
           WHEN NVL(pt.exp_total,0) > 0 AND NVL(pt.inv_total,0) = 0 THEN CASE
                  WHEN TRIM(ffv.description) IS NULL THEN 0
                  WHEN pt.exp_total <= TO_NUMBER(TRIM(ffv.description)) THEN 1 ELSE 0 END
           WHEN NVL(pt.exp_total,0) = 0 AND NVL(pt.inv_total,0) > 0 THEN CASE
                  WHEN TRIM(ffv.tag) IS NULL THEN 0
                  WHEN pt.inv_total <= TO_NUMBER(TRIM(ffv.tag)) THEN 1 ELSE 0 END
           ELSE 0
         END can_approve
  FROM mgr_chain mc
  CROSS JOIN pr_totals_agg pt
  LEFT JOIN fnd_lookup_values_vl ffv
    ON ffv.lookup_type = 'TER_SIGN_APPROVAL_LIMIT'
   AND ffv.enabled_flag = 'Y'
   AND TRIM(ffv.lookup_code) = TRIM(mc.grade_lookup_code)
   AND NVL(ffv.start_date_active, TRUNC(SYSDATE)) <= TRUNC(SYSDATE)
   AND (ffv.end_date_active IS NULL OR ffv.end_date_active >= TRUNC(SYSDATE))
)
SELECT * FROM scored ORDER BY lvl]]>
         </sql>
      </dataSet>
      <dataSet name="7" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[WITH req_hdr AS (
  SELECT prh.overriding_approver_id, prh.preparer_id
  FROM   por_requisition_headers_all prh
  WHERE  prh.requisition_header_id = TO_NUMBER(:req_header_id)
),
root_ctx AS (
  SELECT NVL(rh.overriding_approver_id, rh.preparer_id) AS root_person_id FROM req_hdr rh
),
pr_totals AS (
  SELECT prh.requisition_header_id,
         SUM(CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
                  THEN NVL(prd.distribution_amount, 0) ELSE 0 END) inv_total,
         SUM(CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
                  THEN 0 ELSE NVL(prd.distribution_amount, 0) END) exp_total
  FROM por_requisition_headers_all prh
  JOIN por_requisition_lines_all prl ON prl.requisition_header_id = prh.requisition_header_id
  JOIN por_req_distributions_all prd ON prd.requisition_line_id = prl.requisition_line_id
  JOIN gl_code_combinations gcc ON gcc.code_combination_id = prd.code_combination_id
  WHERE prh.requisition_header_id = TO_NUMBER(:req_header_id)
  GROUP BY prh.requisition_header_id
),
pr_totals_agg AS (
  SELECT NVL(MAX(t.inv_total),0) inv_total, NVL(MAX(t.exp_total),0) exp_total FROM pr_totals t
),
grade_for_person AS (
  SELECT x.person_id, pgt.name AS grade_lookup_code
  FROM (
    SELECT paf.person_id, paf.grade_id,
           ROW_NUMBER() OVER (PARTITION BY paf.person_id ORDER BY paf.effective_start_date DESC) rn
    FROM per_all_assignments_m paf
    WHERE paf.primary_assignment_flag = 'Y'
    AND paf.effective_start_date <= TRUNC(SYSDATE)
    AND (paf.effective_end_date IS NULL OR paf.effective_end_date >= TRUNC(SYSDATE))
  ) x
  LEFT JOIN per_grades_f pg ON pg.grade_id = x.grade_id
    AND pg.effective_start_date <= TRUNC(SYSDATE)
    AND (pg.effective_end_date IS NULL OR pg.effective_end_date >= TRUNC(SYSDATE))
  LEFT JOIN per_grades_f_tl pgt ON pgt.grade_id = x.grade_id
    AND pgt.language = NVL(USERENV('LANG'), 'US')
    AND pgt.effective_start_date <= TRUNC(SYSDATE)
    AND (pgt.effective_end_date IS NULL OR pgt.effective_end_date >= TRUNC(SYSDATE))
  WHERE x.rn = 1
),
username_for_person AS (
  SELECT person_id, username FROM (
    SELECT u.person_id, u.username,
           ROW_NUMBER() OVER (PARTITION BY u.person_id ORDER BY NVL(u.last_update_date,u.creation_date) DESC) rn
    FROM per_users u WHERE NVL(u.active_flag,'Y') = 'Y'
  ) z WHERE z.rn = 1
),
mgr_edges AS (
  SELECT DISTINCT pasf.person_id, pasf.manager_id
  FROM per_assignment_supervisors_f pasf
  WHERE pasf.manager_type = 'LINE_MANAGER'
  AND pasf.effective_start_date <= TRUNC(SYSDATE)
  AND (pasf.effective_end_date IS NULL OR pasf.effective_end_date >= TRUNC(SYSDATE))
  AND pasf.manager_id IS NOT NULL AND pasf.manager_id <> pasf.person_id
),
mgr_chain_base AS (
  SELECT CAST(1 AS NUMBER(10,0)) lvl, rc.root_person_id person_id FROM root_ctx rc
  UNION ALL
  SELECT CAST(LEVEL+1 AS NUMBER(10,0)), e.manager_id
  FROM mgr_edges e
  CONNECT BY NOCYCLE PRIOR e.manager_id = e.person_id
  START WITH e.person_id = (SELECT root_person_id FROM root_ctx)
),
mgr_chain AS (
  SELECT m.lvl, m.person_id, ufp.username,
         COALESCE(NULLIF(TRIM(NVL(ppnf.first_name,'')||' '||NVL(ppnf.last_name,'')),''),
                  ppnf.full_name) approver_name,
         gfp.grade_lookup_code
  FROM mgr_chain_base m
  LEFT JOIN per_person_names_f ppnf ON ppnf.person_id = m.person_id
    AND ppnf.name_type = 'GLOBAL'
    AND ppnf.effective_start_date <= TRUNC(SYSDATE)
    AND (ppnf.effective_end_date IS NULL OR ppnf.effective_end_date >= TRUNC(SYSDATE))
  LEFT JOIN username_for_person ufp ON ufp.person_id = m.person_id
  LEFT JOIN grade_for_person gfp ON gfp.person_id = m.person_id
),
scored AS (
  SELECT mc.lvl, mc.person_id,
         CASE
           WHEN mc.grade_lookup_code IS NULL OR ffv.lookup_code IS NULL THEN 0
           WHEN NVL(pt.exp_total,0) = 0 AND NVL(pt.inv_total,0) = 0 THEN 0
           WHEN NVL(pt.exp_total,0) > 0 AND TRIM(ffv.description) IS NOT NULL
            AND NOT REGEXP_LIKE(TRIM(ffv.description), '^-?[0-9]+(\.[0-9]+)?$') THEN 0
           WHEN NVL(pt.inv_total,0) > 0 AND TRIM(ffv.tag) IS NOT NULL
            AND NOT REGEXP_LIKE(TRIM(ffv.tag), '^-?[0-9]+(\.[0-9]+)?$') THEN 0
           WHEN NVL(pt.exp_total,0) > 0 AND NVL(pt.inv_total,0) > 0 THEN CASE
                  WHEN TRIM(ffv.description) IS NULL OR TRIM(ffv.tag) IS NULL THEN 0
                  WHEN pt.exp_total <= TO_NUMBER(TRIM(ffv.description))
                   AND pt.inv_total <= TO_NUMBER(TRIM(ffv.tag)) THEN 1 ELSE 0 END
           WHEN NVL(pt.exp_total,0) > 0 AND NVL(pt.inv_total,0) = 0 THEN CASE
                  WHEN TRIM(ffv.description) IS NULL THEN 0
                  WHEN pt.exp_total <= TO_NUMBER(TRIM(ffv.description)) THEN 1 ELSE 0 END
           WHEN NVL(pt.exp_total,0) = 0 AND NVL(pt.inv_total,0) > 0 THEN CASE
                  WHEN TRIM(ffv.tag) IS NULL THEN 0
                  WHEN pt.inv_total <= TO_NUMBER(TRIM(ffv.tag)) THEN 1 ELSE 0 END
           ELSE 0
         END can_approve
  FROM mgr_chain mc
  CROSS JOIN pr_totals_agg pt
  LEFT JOIN fnd_lookup_values_vl ffv
    ON ffv.lookup_type = 'TER_SIGN_APPROVAL_LIMIT'
   AND ffv.enabled_flag = 'Y'
   AND TRIM(ffv.lookup_code) = TRIM(mc.grade_lookup_code)
   AND NVL(ffv.start_date_active, TRUNC(SYSDATE)) <= TRUNC(SYSDATE)
   AND (ffv.end_date_active IS NULL OR ffv.end_date_active >= TRUNC(SYSDATE))
)
SELECT COUNT(*) AS scored_rows,
       SUM(can_approve) AS sum_can_approve,
       SUM(CASE WHEN can_approve = 1 THEN 1 ELSE 0 END) AS pass_count,
       MIN(CASE WHEN can_approve = 1 THEN lvl END) AS min_pass_lvl
FROM scored]]>
         </sql>
      </dataSet>
      <dataSet name="8" type="complex">
         <sql dataSourceRef="ApplicationDB_FSCM">
            <![CDATA[WITH req_hdr AS (
  SELECT prh.overriding_approver_id, prh.preparer_id
  FROM   por_requisition_headers_all prh
  WHERE  prh.requisition_header_id = TO_NUMBER(:req_header_id)
),
root_ctx AS (
  SELECT NVL(rh.overriding_approver_id, rh.preparer_id) AS root_person_id FROM req_hdr rh
),
pr_totals AS (
  SELECT prh.requisition_header_id,
         SUM(CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
                  THEN NVL(prd.distribution_amount, 0) ELSE 0 END) inv_total,
         SUM(CASE WHEN gcc.segment2 BETWEEN '0020007' AND '0020009'
                  THEN 0 ELSE NVL(prd.distribution_amount, 0) END) exp_total
  FROM por_requisition_headers_all prh
  JOIN por_requisition_lines_all prl ON prl.requisition_header_id = prh.requisition_header_id
  JOIN por_req_distributions_all prd ON prd.requisition_line_id = prl.requisition_line_id
  JOIN gl_code_combinations gcc ON gcc.code_combination_id = prd.code_combination_id
  WHERE prh.requisition_header_id = TO_NUMBER(:req_header_id)
  GROUP BY prh.requisition_header_id
),
pr_totals_agg AS (
  SELECT NVL(MAX(t.inv_total),0) inv_total, NVL(MAX(t.exp_total),0) exp_total FROM pr_totals t
),
grade_for_person AS (
  SELECT x.person_id, pgt.name AS grade_lookup_code
  FROM (
    SELECT paf.person_id, paf.grade_id,
           ROW_NUMBER() OVER (PARTITION BY paf.person_id ORDER BY paf.effective_start_date DESC) rn
    FROM per_all_assignments_m paf
    WHERE paf.primary_assignment_flag = 'Y'
    AND paf.effective_start_date <= TRUNC(SYSDATE)
    AND (paf.effective_end_date IS NULL OR paf.effective_end_date >= TRUNC(SYSDATE))
  ) x
  LEFT JOIN per_grades_f pg ON pg.grade_id = x.grade_id
    AND pg.effective_start_date <= TRUNC(SYSDATE)
    AND (pg.effective_end_date IS NULL OR pg.effective_end_date >= TRUNC(SYSDATE))
  LEFT JOIN per_grades_f_tl pgt ON pgt.grade_id = x.grade_id
    AND pgt.language = NVL(USERENV('LANG'), 'US')
    AND pgt.effective_start_date <= TRUNC(SYSDATE)
    AND (pgt.effective_end_date IS NULL OR pgt.effective_end_date >= TRUNC(SYSDATE))
  WHERE x.rn = 1
),
username_for_person AS (
  SELECT person_id, username FROM (
    SELECT u.person_id, u.username,
           ROW_NUMBER() OVER (PARTITION BY u.person_id ORDER BY NVL(u.last_update_date,u.creation_date) DESC) rn
    FROM per_users u WHERE NVL(u.active_flag,'Y') = 'Y'
  ) z WHERE z.rn = 1
),
mgr_edges AS (
  SELECT DISTINCT pasf.person_id, pasf.manager_id
  FROM per_assignment_supervisors_f pasf
  WHERE pasf.manager_type = 'LINE_MANAGER'
  AND pasf.effective_start_date <= TRUNC(SYSDATE)
  AND (pasf.effective_end_date IS NULL OR pasf.effective_end_date >= TRUNC(SYSDATE))
  AND pasf.manager_id IS NOT NULL AND pasf.manager_id <> pasf.person_id
),
mgr_chain_base AS (
  SELECT CAST(1 AS NUMBER(10,0)) lvl, rc.root_person_id person_id FROM root_ctx rc
  UNION ALL
  SELECT CAST(LEVEL+1 AS NUMBER(10,0)), e.manager_id
  FROM mgr_edges e
  CONNECT BY NOCYCLE PRIOR e.manager_id = e.person_id
  START WITH e.person_id = (SELECT root_person_id FROM root_ctx)
),
mgr_chain AS (
  SELECT m.lvl, m.person_id, ufp.username,
         COALESCE(NULLIF(TRIM(NVL(ppnf.first_name,'')||' '||NVL(ppnf.last_name,'')),''),
                  ppnf.full_name) approver_name,
         gfp.grade_lookup_code
  FROM mgr_chain_base m
  LEFT JOIN per_person_names_f ppnf ON ppnf.person_id = m.person_id
    AND ppnf.name_type = 'GLOBAL'
    AND ppnf.effective_start_date <= TRUNC(SYSDATE)
    AND (ppnf.effective_end_date IS NULL OR ppnf.effective_end_date >= TRUNC(SYSDATE))
  LEFT JOIN username_for_person ufp ON ufp.person_id = m.person_id
  LEFT JOIN grade_for_person gfp ON gfp.person_id = m.person_id
),
scored AS (
  SELECT mc.lvl, mc.person_id,
         CASE
           WHEN mc.grade_lookup_code IS NULL OR ffv.lookup_code IS NULL THEN 0
           WHEN NVL(pt.exp_total,0) = 0 AND NVL(pt.inv_total,0) = 0 THEN 0
           WHEN NVL(pt.exp_total,0) > 0 AND TRIM(ffv.description) IS NOT NULL
            AND NOT REGEXP_LIKE(TRIM(ffv.description), '^-?[0-9]+(\.[0-9]+)?$') THEN 0
           WHEN NVL(pt.inv_total,0) > 0 AND TRIM(ffv.tag) IS NOT NULL
            AND NOT REGEXP_LIKE(TRIM(ffv.tag), '^-?[0-9]+(\.[0-9]+)?$') THEN 0
           WHEN NVL(pt.exp_total,0) > 0 AND NVL(pt.inv_total,0) > 0 THEN CASE
                  WHEN TRIM(ffv.description) IS NULL OR TRIM(ffv.tag) IS NULL THEN 0
                  WHEN pt.exp_total <= TO_NUMBER(TRIM(ffv.description))
                   AND pt.inv_total <= TO_NUMBER(TRIM(ffv.tag)) THEN 1 ELSE 0 END
           WHEN NVL(pt.exp_total,0) > 0 AND NVL(pt.inv_total,0) = 0 THEN CASE
                  WHEN TRIM(ffv.description) IS NULL THEN 0
                  WHEN pt.exp_total <= TO_NUMBER(TRIM(ffv.description)) THEN 1 ELSE 0 END
           WHEN NVL(pt.exp_total,0) = 0 AND NVL(pt.inv_total,0) > 0 THEN CASE
                  WHEN TRIM(ffv.tag) IS NULL THEN 0
                  WHEN pt.inv_total <= TO_NUMBER(TRIM(ffv.tag)) THEN 1 ELSE 0 END
           ELSE 0
         END can_approve
  FROM mgr_chain mc
  CROSS JOIN pr_totals_agg pt
  LEFT JOIN fnd_lookup_values_vl ffv
    ON ffv.lookup_type = 'TER_SIGN_APPROVAL_LIMIT'
   AND ffv.enabled_flag = 'Y'
   AND TRIM(ffv.lookup_code) = TRIM(mc.grade_lookup_code)
   AND NVL(ffv.start_date_active, TRUNC(SYSDATE)) <= TRUNC(SYSDATE)
   AND (ffv.end_date_active IS NULL OR ffv.end_date_active >= TRUNC(SYSDATE))
)
SELECT lvl, person_id, COUNT(*) AS cnt
FROM scored
GROUP BY lvl, person_id
HAVING COUNT(*) > 1
ORDER BY lvl, person_id]]>
         </sql>
      </dataSet>
   </dataSets>
